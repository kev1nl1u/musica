# Deployment-specific values. Copy to config.env (gitignored) and fill in.
# A real environment variable of the same name takes precedence over this file.

# Deezer user whose public playlists are reconciled. Find it in any playlist
# URL: deezer.com/<lang>/profile/<THIS_ID>. Public, no token needed.
DEEZER_USER=0

# Where the sibling apps are served, for the dashboard header links.
# Leave blank to hide a link.
NAVIDROME_URL=https://navidrome.example.com
DEEMIX_URL=https://deemix.example.com
