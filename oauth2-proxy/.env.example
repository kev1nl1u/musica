# Copy to .env and fill in. Never commit the result.
#
# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# Application type: "Web application"
# Authorised redirect URI: https://auth.example.com/oauth2/callback
# Leave "Authorised JavaScript origins" empty -- server-side flow only.
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# openssl rand -base64 32 | tr -- '+/' '-_'
# Rotating this invalidates every session.
OAUTH2_PROXY_COOKIE_SECRET=

# Domains. redirect-url is the Google-registered callback; cookie-domain spans
# the auth host and every protected subdomain; whitelist-domain bounds where
# ?rd= may send the browser after login.
OAUTH2_PROXY_REDIRECT_URL=https://auth.example.com/oauth2/callback
OAUTH2_PROXY_COOKIE_DOMAINS=.example.com
OAUTH2_PROXY_WHITELIST_DOMAINS=.example.com
